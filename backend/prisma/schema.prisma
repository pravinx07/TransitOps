generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

model User {
  id             String    @id @default(cuid())
  name           String
  email          String    @unique
  password       String
  role           Role
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Settings {
  id           String   @id @default("global")
  depotName    String?
  currency     String   @default("USD ($)")
  distanceUnit String   @default("Kilometers (km)")
  rbac         Json?
  updatedAt    DateTime @updatedAt
}

model Vehicle {
  id        String        @id @default(cuid())
  regNo     String        @unique
  model     String
  type      String
  capacity  String
  odometer  Int
  avgCost   Int
  status    VehicleStatus @default(AVAILABLE)
  region    String        @default("North")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  fuelLogs  FuelLog[]
  expenses  Expense[]
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  ON_LEAVE
  OFF_DUTY
  SUSPENDED
}

model Driver {
  id              String       @id @default(cuid())
  name            String
  licenseNumber   String       @unique
  licenseCategory String
  licenseExpiry   DateTime
  contactNumber   String
  safetyScore     Float        @default(100)
  status          DriverStatus @default(AVAILABLE)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model FuelLog {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date      DateTime
  liters    Float
  fuelCost  Float
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ExpenseStatus {
  PENDING
  AVAILABLE
  COMPLETED
}

model Expense {
  id          String        @id @default(cuid())
  tripRef     String
  vehicleId   String
  vehicle     Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  toll        Float         @default(0)
  other       Float         @default(0)
  maintenance Float         @default(0)
  status      ExpenseStatus @default(PENDING)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}
